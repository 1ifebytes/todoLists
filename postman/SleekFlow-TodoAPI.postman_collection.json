                "key": "Authorization",
                "value": "Bearer {{jwt_token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Review PR #42 - In Progress\",\n  \"status\": \"IN_PROGRESS\",\n  \"description\": \"Currently reviewing the changes\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/todos/{{todo_id}}",
              "host": ["{{baseUrl}}"],
              "path": ["todos", "{{todo_id}}"]
            }
          },
          "response": []
        },
        {
          "name": "Complete Todo",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{jwt_token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"COMPLETED\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/todos/{{todo_id}}",
              "host": ["{{baseUrl}}"],
              "path": ["todos", "{{todo_id}}"]
            }
          },
          "response": []
        },
        {
          "name": "Delete Todo",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{jwt_token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/todos/{{todo_id}}",
              "host": ["{{baseUrl}}"],
              "path": ["todos", "{{todo_id}}"]
            }
          },
          "response": []
        }
