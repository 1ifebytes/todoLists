    {
      "name": "Todo CRUD",
      "item": [
        {
          "name": "Create Todo",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var jsonData = pm.response.json();",
                  "if (jsonData.success && jsonData.data) {",
                  "    pm.collectionVariables.set('todo_id', jsonData.data.id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{jwt_token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Review PR #42\",\n  \"description\": \"Review and merge the feature branch\",\n  \"priority\": \"HIGH\",\n  \"dueDate\": \"2025-06-15T10:00:00\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/todos",
              "host": ["{{baseUrl}}"],
              "path": ["todos"]
            }
          },
          "response": []
        },
        {
          "name": "Create Todo with Tags",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{jwt_token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Buy groceries\",\n  \"priority\": \"MEDIUM\",\n  \"tags\": [\"Personal\", \"Shopping\"]\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/todos",
              "host": ["{{baseUrl}}"],
              "path": ["todos"]
            }
          },
          "response": []
        },
        {
          "name": "List All Todos",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{jwt_token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/todos?page=0&size=20&sortBy=dueDate&sortOrder=ASC",
              "host": ["{{baseUrl}}"],
              "path": ["todos"],
              "query": [
                {
                  "key": "page",
                  "value": "0"
                },
                {
                  "key": "size",
                  "value": "20"
                },
                {
                  "key": "sortBy",
                  "value": "dueDate"
                },
                {
                  "key": "sortOrder",
                  "value": "ASC"
                }
              ]
            }
          },
          "response": []
        },
        {
          "name": "Filter by Status",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{jwt_token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/todos?status=IN_PROGRESS&priority=HIGH",
              "host": ["{{baseUrl}}"],
              "path": ["todos"],
              "query": [
                {
                  "key": "status",
                  "value": "IN_PROGRESS"
                },
                {
                  "key": "priority",
                  "value": "HIGH"
                }
              ]
            }
          },
          "response": []
        },
        {
          "name": "Filter by Date Range",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{jwt_token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/todos?dueDateFrom=2025-06-01T00:00:00&dueDateTo=2025-06-30T23:59:59",
              "host": ["{{baseUrl}}"],
              "path": ["todos"],
              "query": [
                {
                  "key": "dueDateFrom",
                  "value": "2025-06-01T00:00:00"
                },
                {
                  "key": "dueDateTo",
                  "value": "2025-06-30T23:59:59"
                }
              ]
            }
          },
          "response": []
        },
        {
          "name": "Filter by Tags",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{jwt_token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/todos?tags=Work,Urgent",
              "host": ["{{baseUrl}}"],
              "path": ["todos"],
              "query": [
                {
                  "key": "tags",
                  "value": "Work,Urgent"
                }
              ]
            }
          },
          "response": []
        },
        {
          "name": "Get Todo by ID",
          "request": {
            "method": "GET",
            "header": [
